{
  "permission": {
    "*": "ask",
    "path": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "grep": "allow",
    "find": "allow",
    "ls": "allow",
    "read": "allow",
    "write": "ask",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "grep *": "allow",
      "ls *": "allow",
      "find *": "allow",
      "cat *": "allow",
      "wc *": "allow",
      "git status": "allow",
      "git diff": "allow",
      "git *": "ask",
      "rm -rf *": "deny"
    },
    "mcp": { "mcp_status": "allow" },
    "skill": { "*": "allow" },
    "external_directory": "ask"
  }
}
