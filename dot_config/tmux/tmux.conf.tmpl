# --- Terminal & Colors (Vim Support) ---
set -g default-terminal "tmux-256color"
set -sg terminal-overrides ',*:Tc'

# --- General Settings ---
set -g mouse on                 # Enable mouse
set -g escape-time 0            # Remove delay for escape key (vim compatibility)
set -g history-limit 10000      # Reasonable history limit
set -g detach-on-destroy off     # don't exit from tmux when closing a session
set -g set-clipboard on          # use system clipboard
set -g status-position top       # macOS / darwin style

# --- Indexing (Start at 1) ---
set -g base-index 1             # Start windows at 1
set -g pane-base-index 1        # Start panes at 1
set-window-option -g pane-base-index 1
set-option -g renumber-windows on # Keep window numbers contiguous

# --- Vi Mode ---
set-window-option -g mode-keys vi
bind-key -T copy-mode-vi v send -X begin-selection
bind-key -T copy-mode-vi y send -X copy-selection-and-cancel
unbind -T copy-mode-vi MouseDragEnd1Pane

# --- Utilities ---
# Reload config with Prefix + R
bind R source-file ~/.tmux.conf \; display-message "Config reloaded!"
