[
{{- if eq .chezmoi.os "darwin" }}
  {
    "context": "Workspace",
    "bindings": {
      "cmd-b": "workspace::ToggleRightDock",
      "cmd-alt-b": "workspace::ToggleLeftDock",
    }
  },
{{- end }}
{{- if eq .chezmoi.os "linux" }}
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-shift-b": "workspace::ToggleRightDock",
      "ctrl-alt-b": "workspace::ToggleLeftDock"
    }
  },
{{- end }}
  {
    "context": "VimControl && vim_mode == normal && !menu",
    "bindings": {
      "g o": "outline::Toggle",
      "g shift-o": "project_symbols::Toggle",
      "shift-y": ["workspace::SendKeystrokes", "y $"],
      "space space": "file_finder::Toggle"
    }
  },
  {
    "context": "vim_mode == visual && !menu",
    "bindings": {
      ">": ["workspace::SendKeystrokes", "> g v"],
      "<": ["workspace::SendKeystrokes", "< g v"],
      "shift-s": "vim::PushAddSurrounds"
    }
  },
  {
    "context": "(vim_mode == normal || vim_mode == visual) && !menu",
    "bindings": {
      "space /": "buffer_search::DeployReplace"
    }
  },
  {
    "context": "((VimControl && !menu) || (!Editor && !Terminal))",
    "bindings": {
      "ctrl-w o": "pane::JoinAll",
      "ctrl-w ctrl-o": "workspace::CloseInactiveTabsAndPanes",
      "ctrl-w shift-o": "workspace::CloseAllDocks"
    }
  }
]
